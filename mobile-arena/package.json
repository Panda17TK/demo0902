{
  "name": "wave-arena",
  "version": "1.0.0",
  "description": "見下ろし型サバイバル・アクションシューター（ウェーブ制ローグライト）。静的PWA＋Capacitorでネイティブ化可。",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "serve": "python3 -m http.server 8080",
    "build": "node scripts/build-www.mjs",
    "sync": "npm run build && npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/preferences": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  },
  "license": "MIT"
}
